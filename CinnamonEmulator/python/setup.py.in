from setuptools import setup, find_packages
from setuptools.dist import Distribution

class BinaryDistribution(Distribution):
    """Distribution which always forces a binary package with platform name"""
    def has_ext_modules(foo):
        return True

setup(
    name='cinnamon_emulator',
    version='${PROJECT_VERSION}',
    author='Siddharth Jayashankar',
    author_email='sidjay@cmu.edu',
    description='Interpreter for Compiler',
    packages=find_packages('${CMAKE_CURRENT_BINARY_DIR}'),
    package_data={
        'cinnamon_emulator': ['$<TARGET_FILE_NAME:cinnamon_emulator_py>'],
    },
    distclass=BinaryDistribution,
    install_requires=[
        'psutil',
    ],
)
